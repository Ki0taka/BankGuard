# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=sims_db

# JWT Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION=1h

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEYS=replace_with_exactly_32_char_key

# Google APIs / AI extraction
GOOGLE_API_KEY=

# EmailJS (optional; SMTP is used as fallback)
EMAILJS_SERVICE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
EMAILJS_INVITE_TEMPLATE_ID=
EMAILJS_OTP_TEMPLATE_ID=

# Mail (SMTP fallback)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_SECURE=true
MAIL_FROM="SIMS <otp@yourdomain.com>"

# Frontend
FRONTEND_URL=http://localhost:5173
