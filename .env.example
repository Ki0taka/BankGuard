# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=sims_db

# JWT Authentication
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRATION=1h

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# Redis (used for BullMQ and Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=32_character_random_string_here

# Mail (SMTP)
# Recommended for real inbox delivery: Resend SMTP
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=re_xxxxxxxxx
#
# Alternative: Brevo SMTP
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=465
# SMTP_USER=your-brevo-smtp-login
# SMTP_PASSWORD=your-brevo-smtp-key
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=
SMTP_SECURE=true
MAIL_FROM="SIMS <otp@yourdomain.com>"
FRONTEND_URL=http://localhost:5173
