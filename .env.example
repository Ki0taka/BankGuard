# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=sims_db

# JWT Authentication
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRATION=1h

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# Redis (used for BullMQ and Caching)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Security
BCRYPT_SALT_ROUNDS=12
ENCRYPTION_KEY=32_character_random_string_here

# Mail (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="SIMS System <noreply@sims.com>"
